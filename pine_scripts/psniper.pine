//@version=6
strategy("psniper", overlay=true, initial_capital=5000, pyramiding=0)

// backend_strategy: psniper
// This file name is the strategy key used by the dashboard Pine Script dropdown.

emaFast = ta.ema(close, 8)
emaSlow = ta.ema(close, 21)
emaTrend = ta.ema(close, 55)
rsiValue = ta.rsi(close, 14)

longSignal = ta.crossover(emaFast, emaSlow) and close > emaTrend and rsiValue > 50 and rsiValue < 75
exitSignal = ta.crossunder(emaFast, emaSlow)

if longSignal
    strategy.entry("BUY", strategy.long)

if exitSignal
    strategy.close("BUY", comment="SELL")

plot(emaFast, color=color.new(color.green, 0), title="EMA Fast")
plot(emaSlow, color=color.new(color.orange, 0), title="EMA Slow")
plot(emaTrend, color=color.new(color.blue, 0), title="EMA Trend")
plotshape(longSignal, title="Buy", style=shape.triangleup, location=location.belowbar, color=color.new(color.green, 0), size=size.tiny, text="BUY")
plotshape(exitSignal, title="Sell", style=shape.triangledown, location=location.abovebar, color=color.new(color.red, 0), size=size.tiny, text="SELL")
