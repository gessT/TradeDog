// ═══════════════════════════════════════════════════════════════════════════════════════════════
// 左侧交易策略 - Left-Side Trading Strategy v1.0
// 用于 XAUUSD / MGC 黄金 5分钟或10分钟周期
// 核心逻辑: 假突破(Liquidity Sweep) + 结构反转(MSS) + 回踩入场
// 目标: 低胜率 + 高盈亏比 (RR > 3)
// ═══════════════════════════════════════════════════════════════════════════════════════════════

//@version=5
strategy("Left-Side Gold [Gess]", 
     overlay         = true, 
     initial_capital  = 100000, 
     default_qty_type = strategy.fixed, 
     default_qty_value= 1, 
     commission_type  = strategy.commission.cash_per_contract, 
     commission_value = 0.5,
     slippage         = 2, 
     pyramiding       = 0,
     calc_on_every_tick = false,
     process_orders_on_close = false)

// ═══════════════════════════════════════════════════════════════════════════════════════════════
//                              1. 输入参数 (INPUT PARAMETERS)
// ═══════════════════════════════════════════════════════════════════════════════════════════════

// --- 趋势过滤 (Trend Filter) ---
string trendFilterGroup = "═══ 趋势过滤 Trend Filter ═══"
trendFilterType   = input.string("Supertrend", "趋势过滤器类型", options=["Supertrend", "EMA200"], group=trendFilterGroup)
htfTimeframe      = input.timeframe("60", "高级别时间周期", group=trendFilterGroup, tooltip="用于判断大趋势方向，默认1小时")
stFactor          = input.float(3.0, "Supertrend 因子", minval=0.5, maxval=10.0, step=0.1, group=trendFilterGroup)
stAtrPeriod       = input.int(10, "Supertrend ATR 周期", minval=1, maxval=50, group=trendFilterGroup)
ema200Period       = input.int(200, "EMA200 周期", minval=50, maxval=500, group=trendFilterGroup)

// --- HalfTrend 设置 ---
string halfTrendGroup = "═══ HalfTrend 确认 ═══"
htAmplitude       = input.int(5, "HalfTrend 振幅", minval=1, maxval=20, group=halfTrendGroup)
htChannelDev      = input.int(2, "HalfTrend 通道偏差", minval=1, maxval=10, group=halfTrendGroup)
useHalfTrend      = input.bool(true, "使用 HalfTrend 确认", group=halfTrendGroup, tooltip="关闭则使用 EMA 交叉确认")
emaFastPeriod     = input.int(9, "确认 EMA 快线", minval=3, maxval=50, group=halfTrendGroup)
emaSlowPeriod     = input.int(21, "确认 EMA 慢线", minval=10, maxval=100, group=halfTrendGroup)

// --- Liquidity Sweep 设置 ---
string sweepGroup = "═══ Liquidity Sweep 假突破 ═══"
swingLookback     = input.int(10, "摆动点回溯周期", minval=3, maxval=30, group=sweepGroup, tooltip="用于检测 Swing Low 的 Pivot 回溯")
sweepValidBars    = input.int(8, "Sweep 有效 K线数", minval=1, maxval=20, group=sweepGroup, tooltip="Sweep 发生后，在多少根 K 线内有效")
sweepWickOnly     = input.bool(true, "仅影线刺穿 (Wick Sweep)", group=sweepGroup, tooltip="true = 影线刺穿后收回; false = 也允许收盘刺穿")

// --- 市场结构 (Market Structure) ---
string mssGroup = "═══ 结构转换 MSS ═══"
mssLookback       = input.int(10, "结构点回溯周期", minval=3, maxval=30, group=mssGroup)
mssValidBars      = input.int(10, "MSS 有效 K线数", minval=1, maxval=30, group=mssGroup, tooltip="结构转换后，在多少根 K 线内有效")

// --- 回踩入场 (Pullback Entry) ---
string entryGroup = "═══ 回踩入场 ═══"
ema20Period       = input.int(20, "回踩 EMA 周期", minval=5, maxval=100, group=entryGroup)
pullbackBuffer    = input.float(0.5, "回踩缓冲 (ATR倍数)", minval=0.0, maxval=3.0, step=0.1, group=entryGroup, tooltip="价格在 EMA ± buffer*ATR 范围内视为回踩")

// --- 风控 (Risk Management) ---
string riskGroup = "═══ 风控 Risk Management ═══"
riskPercent       = input.float(1.0, "每单风险 (%)", minval=0.1, maxval=5.0, step=0.1, group=riskGroup)
atrSLMultiplier   = input.float(0.5, "止损 ATR 缓冲倍数", minval=0.0, maxval=3.0, step=0.1, group=riskGroup, tooltip="止损 = Sweep Low - ATR * 此值")
atrPeriod         = input.int(14, "ATR 周期", minval=5, maxval=50, group=riskGroup)

// --- 出场 (Exit) ---
string exitGroup = "═══ 出场 Exit ═══"
tp1RR             = input.float(2.0, "TP1 盈亏比 (R)", minval=0.5, maxval=10.0, step=0.5, group=exitGroup)
tp2RR             = input.float(4.0, "TP2 盈亏比 (R)", minval=1.0, maxval=20.0, step=0.5, group=exitGroup)
tp1ClosePercent   = input.float(50.0, "TP1 平仓比 (%)", minval=10, maxval=90, step=5, group=exitGroup)
tp2ClosePercent   = input.float(30.0, "TP2 平仓比 (%)", minval=10, maxval=90, step=5, group=exitGroup)
trailAtrMult      = input.float(2.0, "Trailing Stop ATR 倍数", minval=0.5, maxval=5.0, step=0.1, group=exitGroup)
trailType         = input.string("ATR", "Trailing Stop 类型", options=["ATR", "Supertrend"], group=exitGroup)

// --- 显示选项 ---
string displayGroup = "═══ 显示 Display ═══"
showHalfTrend     = input.bool(true, "显示 HalfTrend", group=displayGroup)
showEma20         = input.bool(true, "显示 EMA20", group=displayGroup)
showSweepMarkers  = input.bool(true, "显示 Sweep 标记", group=displayGroup)
showTPLines       = input.bool(true, "显示 TP/SL 线", group=displayGroup)
showStatsTable    = input.bool(true, "显示统计表", group=displayGroup)

// ═══════════════════════════════════════════════════════════════════════════════════════════════
//                              2. 趋势过滤 (1H TREND FILTER)
// ═══════════════════════════════════════════════════════════════════════════════════════════════

// --- 1H Supertrend 函数 ---
f_supertrend(_factor, _period) =>
    [st, dir] = ta.supertrend(_factor, _period)
    [st, dir]

// 从高级别时间周期获取 Supertrend（使用 confirmed bar 避免重绘）
[htfST, htfDir] = request.security(syminfo.tickerid, htfTimeframe, f_supertrend(stFactor, stAtrPeriod), lookahead=barmerge.lookahead_off)

// 从高级别时间周期获取 EMA200
htfEma200 = request.security(syminfo.tickerid, htfTimeframe, ta.ema(close, ema200Period), lookahead=barmerge.lookahead_off)

// 根据用户选择确定趋势方向
// Supertrend: dir == -1 表示上涨趋势; EMA200: close > EMA200 表示上涨趋势
bool trendUp = trendFilterType == "Supertrend" ? (htfDir == -1) : (close > htfEma200)

// ═══════════════════════════════════════════════════════════════════════════════════════════════
//                              3. HALFTREND 计算 (CONFIRMATION)
// ═══════════════════════════════════════════════════════════════════════════════════════════════

// HalfTrend 状态变量
var int htTrend = 0
var int htNextTrend = 0
var float htMaxLowPrice = na
var float htMinHighPrice = na
var float htUp = 0.0
var float htDown = 0.0

// 第一根 K 线初始化
if barstate.isfirst
    htMaxLowPrice := nz(low[1], low)
    htMinHighPrice := nz(high[1], high)

// ATR 和偏差
htAtr2 = ta.atr(100) / 2
htDev = htChannelDev * htAtr2

// 周期内最高价与最低价
htHighPrice = high[math.abs(ta.highestbars(htAmplitude))]
htLowPrice = low[math.abs(ta.lowestbars(htAmplitude))]
htHighMA = ta.sma(high, htAmplitude)
htLowMA = ta.sma(low, htAmplitude)

// 保存上一根 K 线的趋势
htPrevTrend = htTrend

// HalfTrend 趋势转换逻辑 - 检测上升趋势
if htNextTrend == 1
    htMaxLowPrice := math.max(htLowPrice, htMaxLowPrice)
    if htHighMA < htMaxLowPrice and close < nz(low[1], low)
        htTrend := 1
        htNextTrend := 0
        htMinHighPrice := htHighPrice

// HalfTrend 趋势转换逻辑 - 检测下降趋势
else
    htMinHighPrice := math.min(htHighPrice, htMinHighPrice)
    if htLowMA > htMinHighPrice and close > nz(high[1], high)
        htTrend := 0
        htNextTrend := 1
        htMaxLowPrice := htLowPrice

// 计算 HalfTrend 线位置
float htAtrHigh = 0.0
float htAtrLow = 0.0

if htTrend == 0
    if not na(htTrend[1]) and htTrend[1] != 0
        htUp := na(htDown[1]) ? htDown : htDown[1]
    else
        htUp := na(htUp[1]) ? htMaxLowPrice : math.max(htMaxLowPrice, htUp[1])
    htAtrHigh := htUp + htDev
    htAtrLow := htUp - htDev
else
    if not na(htTrend[1]) and htTrend[1] != 1
        htDown := na(htUp[1]) ? htUp : htUp[1]
    else
        htDown := na(htDown[1]) ? htMinHighPrice : math.min(htMinHighPrice, htDown[1])
    htAtrHigh := htDown + htDev
    htAtrLow := htDown - htDev

// HalfTrend 值
htValue = htTrend == 0 ? htUp : htDown
htColor = htTrend == 0 ? color.rgb(0, 150, 255) : color.rgb(255, 50, 50)

// HalfTrend 信号
htBullFlip = htTrend == 0 and htPrevTrend == 1    // 空转多
htBearFlip = htTrend == 1 and htPrevTrend == 0    // 多转空

// --- 替代确认: EMA 交叉 ---
emaFast = ta.ema(close, emaFastPeriod)
emaSlow = ta.ema(close, emaSlowPeriod)
emaBullCross = ta.crossover(emaFast, emaSlow)
emaBullish = emaFast > emaSlow

// 综合确认信号
bool confirmBullish = useHalfTrend ? (htTrend == 0) : emaBullish
bool confirmBullFlip = useHalfTrend ? htBullFlip : emaBullCross

// ═══════════════════════════════════════════════════════════════════════════════════════════════
//                              4. LIQUIDITY SWEEP 检测 (假突破)
// ═══════════════════════════════════════════════════════════════════════════════════════════════

// 检测 Swing Low (摆动低点)
swingLow = ta.pivotlow(low, swingLookback, swingLookback)

// 追踪最近的有效 Swing Low
var float lastSwingLow = na
var int lastSwingLowBar = na

if not na(swingLow)
    lastSwingLow := swingLow
    lastSwingLowBar := bar_index - swingLookback  // pivot 延迟 swingLookback 根 K 线确认

// 检测 Liquidity Sweep（假突破）
// 条件: 价格最低点刺穿前低 → 但收盘价收回前低上方
bool isSweep = false
if not na(lastSwingLow)
    if sweepWickOnly
        // 仅影线刺穿: low 破前低但 close 收回
        isSweep := low < lastSwingLow and close > lastSwingLow
    else
        // 也允许收盘破位后下一根收回
        isSweep := (low < lastSwingLow and close > lastSwingLow) or (close[1] < lastSwingLow and close > lastSwingLow)

// 存储 Sweep 信息（有效期限制）
var bool sweepActive = false
var float sweepLowPrice = na
var int sweepBar = na

if isSweep
    sweepActive := true
    sweepLowPrice := math.min(low, lastSwingLow)  // 取刺穿后的实际最低点
    sweepBar := bar_index

// Sweep 过期检查
if sweepActive and (bar_index - sweepBar > sweepValidBars)
    sweepActive := false

// ═══════════════════════════════════════════════════════════════════════════════════════════════
//                              5. 市场结构转换 (MARKET STRUCTURE SHIFT)
// ═══════════════════════════════════════════════════════════════════════════════════════════════

// 检测 Swing High 和 Swing Low 用于结构分析
swingHighForMSS = ta.pivothigh(high, mssLookback, mssLookback)
swingLowForMSS = ta.pivotlow(low, mssLookback, mssLookback)

// 追踪最近两个 Swing Low（用于 Higher Low 判断）
var float prevSwingLowMSS = na
var float currSwingLowMSS = na
var int currSwingLowMSSBar = na

if not na(swingLowForMSS)
    prevSwingLowMSS := currSwingLowMSS
    currSwingLowMSS := swingLowForMSS
    currSwingLowMSSBar := bar_index - mssLookback

// 追踪最近的 Swing High（用于 BOS 判断）
var float lastSwingHighMSS = na
var int lastSwingHighMSSBar = na

if not na(swingHighForMSS)
    lastSwingHighMSS := swingHighForMSS
    lastSwingHighMSSBar := bar_index - mssLookback

// Higher Low: 当前摆动低点 > 前一个摆动低点
bool higherLow = not na(prevSwingLowMSS) and not na(currSwingLowMSS) and currSwingLowMSS > prevSwingLowMSS

// Break of Structure (BOS): 价格突破前一个 Swing High
bool bos = not na(lastSwingHighMSS) and close > lastSwingHighMSS and close[1] <= lastSwingHighMSS

// Market Structure Shift 信号
var bool mssActive = false
var int mssBar = na

if (higherLow or bos) and sweepActive
    mssActive := true
    mssBar := bar_index

// MSS 过期检查
if mssActive and (bar_index - mssBar > mssValidBars)
    mssActive := false

// ═══════════════════════════════════════════════════════════════════════════════════════════════
//                              6. 回踩入场逻辑 (PULLBACK ENTRY)
// ═══════════════════════════════════════════════════════════════════════════════════════════════

// 回踩 EMA
ema20 = ta.ema(close, ema20Period)
atrValue = ta.atr(atrPeriod)

// 回踩条件: 价格接近 EMA20 (在 EMA ± buffer*ATR 范围内)
float pullbackZoneUpper = ema20 + pullbackBuffer * atrValue
float pullbackZoneLower = ema20 - pullbackBuffer * atrValue
bool priceAtPullback = low <= pullbackZoneUpper and close >= pullbackZoneLower

// 结构位回踩: 价格回到 Higher Low 附近 (当前 swing low ± ATR)
bool priceAtStructure = not na(currSwingLowMSS) and low <= currSwingLowMSS + atrValue and close >= currSwingLowMSS - atrValue * 0.5

// 回踩条件 (EMA 或结构位任意满足)
bool pullbackOK = priceAtPullback or priceAtStructure

// ═══════════════════════════════════════════════════════════════════════════════════════════════
//                              7. 综合入场条件 (ENTRY CONDITIONS)
// ═══════════════════════════════════════════════════════════════════════════════════════════════

// 所有条件必须同时满足:
// 1. 大趋势看多 (1H Supertrend/EMA200)
// 2. 发生了 Liquidity Sweep（假突破低点）
// 3. 出现 Market Structure Shift（Higher Low 或 BOS）
// 4. HalfTrend 或 EMA 确认多头
// 5. 价格回踩 EMA20 或结构位
// 6. 当前无持仓

bool noPosition = strategy.position_size == 0

bool longCondition = trendUp and sweepActive and mssActive and confirmBullish and pullbackOK and noPosition

// ═══════════════════════════════════════════════════════════════════════════════════════════════
//                              8. 风控与仓位管理 (RISK MANAGEMENT)
// ═══════════════════════════════════════════════════════════════════════════════════════════════

// 止损价 = Sweep 最低点 - ATR * 缓冲倍数
float stopLossPrice = sweepActive ? sweepLowPrice - atrValue * atrSLMultiplier : na

// 风险金额 = 账户权益 * 风险比例
float riskAmount = strategy.equity * (riskPercent / 100.0)

// 每单位风险（价格距离）
float riskPerUnit = not na(stopLossPrice) ? close - stopLossPrice : na

// 持仓数量 = 风险金额 / 每单位风险 (防止除零/负数)
float positionSize = (not na(riskPerUnit) and riskPerUnit > 0) ? math.floor(riskAmount / riskPerUnit) : 0

// 确保仓位至少为 1
positionSize := math.max(positionSize, 1)

// ═══════════════════════════════════════════════════════════════════════════════════════════════
//                              9. 入场执行 (ENTRY EXECUTION)
// ═══════════════════════════════════════════════════════════════════════════════════════════════

// 交易状态变量
var float entryPrice = na
var float initialSL = na
var float initialRisk = na
var float tp1Price = na
var float tp2Price = na
var bool tp1Hit = false
var bool tp2Hit = false
var float highestSinceEntry = na
var int totalQty = 0

if longCondition and not na(riskPerUnit) and riskPerUnit > 0
    entryPrice := close
    initialSL := stopLossPrice
    initialRisk := riskPerUnit
    tp1Price := close + initialRisk * tp1RR
    tp2Price := close + initialRisk * tp2RR
    tp1Hit := false
    tp2Hit := false
    highestSinceEntry := high
    totalQty := math.max(int(positionSize), 1)
    
    strategy.entry("Long", strategy.long, qty=totalQty)

// ═══════════════════════════════════════════════════════════════════════════════════════════════
//                              10. 出场管理 (EXIT MANAGEMENT)
// ═══════════════════════════════════════════════════════════════════════════════════════════════

// 更新最高价（用于 Trailing Stop）
if strategy.position_size > 0
    highestSinceEntry := math.max(nz(highestSinceEntry, high), high)

// --- TP1: 2R 平仓 50% ---
int tp1Qty = math.max(int(math.round(totalQty * tp1ClosePercent / 100.0)), 1)

if strategy.position_size > 0 and not tp1Hit and not na(tp1Price) and high >= tp1Price
    tp1Hit := true
    strategy.exit("TP1", "Long", qty=tp1Qty, limit=tp1Price)

// --- TP2: 4R 平仓 30% ---
int tp2Qty = math.max(int(math.round(totalQty * tp2ClosePercent / 100.0)), 1)

if strategy.position_size > 0 and tp1Hit and not tp2Hit and not na(tp2Price) and high >= tp2Price
    tp2Hit := true
    strategy.exit("TP2", "Long", qty=tp2Qty, limit=tp2Price)

// --- 止损管理 ---
// TP1 触发后移动止损到保本
float currentSL = na
if strategy.position_size > 0
    if tp1Hit
        currentSL := entryPrice  // 保本止损
    else
        currentSL := initialSL   // 初始止损

// --- Trailing Stop（TP1 后启用）---
float trailStop = na
if strategy.position_size > 0 and tp1Hit
    if trailType == "ATR"
        trailStop := highestSinceEntry - atrValue * trailAtrMult
    else
        // 使用当前时间周期 Supertrend 作为 trailing
        [localST, localDir] = ta.supertrend(stFactor, stAtrPeriod)
        trailStop := localDir == -1 ? localST : na

    // Trailing Stop 不得低于保本价
    if not na(trailStop) and not na(entryPrice)
        trailStop := math.max(trailStop, entryPrice)

// 综合止损价（取 Trailing Stop 和当前 SL 中的较高者）
float effectiveSL = na
if not na(currentSL) and not na(trailStop)
    effectiveSL := math.max(currentSL, trailStop)
else if not na(trailStop)
    effectiveSL := trailStop
else
    effectiveSL := currentSL

// 执行止损出场
if strategy.position_size > 0 and not na(effectiveSL) and low <= effectiveSL
    strategy.close_all("SL/Trail")
    // 重置状态
    entryPrice := na
    initialSL := na
    tp1Price := na
    tp2Price := na
    tp1Hit := false
    tp2Hit := false
    highestSinceEntry := na
    totalQty := 0

// 仓位关闭后重置状态（防止遗漏）
if strategy.position_size == 0 and not na(entryPrice)
    entryPrice := na
    initialSL := na
    tp1Price := na
    tp2Price := na
    tp1Hit := false
    tp2Hit := false
    highestSinceEntry := na
    totalQty := 0

// ═══════════════════════════════════════════════════════════════════════════════════════════════
//                              11. 图表可视化 (VISUALS)
// ═══════════════════════════════════════════════════════════════════════════════════════════════

// --- 1H 趋势背景 ---
bgcolor(trendUp ? color.new(color.green, 92) : color.new(color.red, 92), title="趋势方向背景")

// --- HalfTrend 线 ---
plot(showHalfTrend ? htValue : na, title="HalfTrend", linewidth=2, color=htColor)

// --- EMA20 回踩线 ---
plot(showEma20 ? ema20 : na, title="EMA20", color=color.new(color.orange, 30), linewidth=1)

// --- Sweep 标记 ---
plotshape(showSweepMarkers and isSweep, title="Liquidity Sweep", style=shape.triangledown, 
     location=location.belowbar, color=color.new(color.purple, 0), size=size.small, text="Sweep")

// --- 入场信号标记 ---
plotshape(longCondition, title="入场信号", style=shape.labelup, 
     location=location.belowbar, color=color.new(color.green, 0), size=size.normal, text="BUY", textcolor=color.white)

// --- MSS 标记 ---
plotshape((higherLow or bos) and sweepActive and not (higherLow or bos)[1], title="MSS", style=shape.diamond, 
     location=location.abovebar, color=color.new(color.teal, 0), size=size.tiny, text="MSS")

// --- TP/SL 水平线（持仓时显示）---
plot(showTPLines and strategy.position_size > 0 ? tp1Price : na, title="TP1 线", color=color.new(color.green, 40), linewidth=1, style=plot.style_linebr)
plot(showTPLines and strategy.position_size > 0 ? tp2Price : na, title="TP2 线", color=color.new(color.blue, 40), linewidth=1, style=plot.style_linebr)
plot(showTPLines and strategy.position_size > 0 ? effectiveSL : na, title="止损线", color=color.new(color.red, 40), linewidth=1, style=plot.style_linebr)

// ═══════════════════════════════════════════════════════════════════════════════════════════════
//                              12. 回测统计表 (BACKTEST STATS TABLE)
// ═══════════════════════════════════════════════════════════════════════════════════════════════

if showStatsTable and barstate.islastconfirmedhistory
    var table statsTable = table.new(position.top_right, 2, 7, bgcolor=color.new(color.black, 80), border_width=1)
    
    // 基础统计
    int totalTrades = strategy.closedtrades
    int winTrades = 0
    float totalProfit = 0.0
    float totalLoss = 0.0
    float maxDD = strategy.max_drawdown
    
    // 遍历已关闭交易计算胜率和盈亏
    for i = 0 to math.max(totalTrades - 1, 0)
        float pnl = strategy.closedtrades.profit(i)
        if pnl > 0
            winTrades += 1
            totalProfit += pnl
        else
            totalLoss += math.abs(pnl)
    
    float winRate = totalTrades > 0 ? (winTrades / totalTrades) * 100 : 0.0
    float profitFactor = totalLoss > 0 ? totalProfit / totalLoss : 0.0
    float netProfit = strategy.netprofit
    float netProfitPct = strategy.initial_capital > 0 ? (netProfit / strategy.initial_capital) * 100 : 0.0
    
    // 表头
    table.cell(statsTable, 0, 0, "指标", text_color=color.white, text_size=size.small)
    table.cell(statsTable, 1, 0, "值", text_color=color.white, text_size=size.small)
    
    // 数据行
    table.cell(statsTable, 0, 1, "总交易数", text_color=color.gray, text_size=size.small)
    table.cell(statsTable, 1, 1, str.tostring(totalTrades), text_color=color.white, text_size=size.small)
    
    table.cell(statsTable, 0, 2, "胜率 Win Rate", text_color=color.gray, text_size=size.small)
    table.cell(statsTable, 1, 2, str.tostring(winRate, "#.1") + "%", text_color=winRate >= 50 ? color.green : color.orange, text_size=size.small)
    
    table.cell(statsTable, 0, 3, "盈亏比 PF", text_color=color.gray, text_size=size.small)
    table.cell(statsTable, 1, 3, str.tostring(profitFactor, "#.2"), text_color=profitFactor >= 1.5 ? color.green : color.orange, text_size=size.small)
    
    table.cell(statsTable, 0, 4, "最大回撤", text_color=color.gray, text_size=size.small)
    table.cell(statsTable, 1, 4, str.tostring(maxDD, "#.2"), text_color=color.red, text_size=size.small)
    
    table.cell(statsTable, 0, 5, "净利润", text_color=color.gray, text_size=size.small)
    table.cell(statsTable, 1, 5, str.tostring(netProfit, "#.2"), text_color=netProfit >= 0 ? color.green : color.red, text_size=size.small)
    
    table.cell(statsTable, 0, 6, "净利润 %", text_color=color.gray, text_size=size.small)
    table.cell(statsTable, 1, 6, str.tostring(netProfitPct, "#.2") + "%", text_color=netProfitPct >= 0 ? color.green : color.red, text_size=size.small)

// ═══════════════════════════════════════════════════════════════════════════════════════════════
//                              13. 警报条件 (ALERT CONDITIONS)
// ═══════════════════════════════════════════════════════════════════════════════════════════════

// --- Webhook 可用的 Alert Conditions ---
alertcondition(isSweep, 
     title="🔻 Liquidity Sweep 检测", 
     message='{"signal":"sweep","ticker":"{{ticker}}","price":{{close}},"time":"{{time}}"}')

alertcondition(longCondition, 
     title="🟢 入场信号", 
     message='{"signal":"long_entry","ticker":"{{ticker}}","price":{{close}},"sl":' + str.tostring(stopLossPrice) + ',"tp1":' + str.tostring(tp1Price) + ',"tp2":' + str.tostring(tp2Price) + ',"time":"{{time}}"}')

alertcondition(strategy.position_size > 0 and tp1Hit and not tp1Hit[1], 
     title="🎯 TP1 触发", 
     message='{"signal":"tp1_hit","ticker":"{{ticker}}","price":{{close}},"time":"{{time}}"}')

alertcondition(strategy.position_size > 0 and tp2Hit and not tp2Hit[1], 
     title="🎯 TP2 触发", 
     message='{"signal":"tp2_hit","ticker":"{{ticker}}","price":{{close}},"time":"{{time}}"}')

alertcondition(strategy.position_size > 0 and not na(effectiveSL) and low <= effectiveSL, 
     title="🔴 止损/Trailing 触发", 
     message='{"signal":"stop_loss","ticker":"{{ticker}}","price":{{close}},"time":"{{time}}"}')

alertcondition(htBullFlip, 
     title="🔵 HalfTrend 转多", 
     message='{"signal":"halftrend_bull","ticker":"{{ticker}}","price":{{close}},"time":"{{time}}"}')

alertcondition(htBearFlip, 
     title="🔴 HalfTrend 转空", 
     message='{"signal":"halftrend_bear","ticker":"{{ticker}}","price":{{close}},"time":"{{time}}"}')

// ═══════════════════════════════════════════════════════════════════════════════════════════════
//                              END OF STRATEGY
// ═══════════════════════════════════════════════════════════════════════════════════════════════
