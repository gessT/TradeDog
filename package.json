{
  "name": "trading-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Scripts to run the Python trading backend with npm",
  "scripts": {
    "setup": "npx cross-env-shell \"pip install -r requirements.txt\"",
    "check:win": "python -c \"from app.main import app; print(app.title)\"",
    "check:mac": "python3 -c \"from app.main import app; print(app.title)\"",
    "dev": "node -e \"const{execSync}=require('child_process');const cmd=process.platform==='win32'?'python':'python3';execSync(cmd+' -m uvicorn app.main:app --host 127.0.0.1 --port 8000 --reload',{stdio:'inherit'})\"",
    "dev:win": "python -m uvicorn app.main:app --host 127.0.0.1 --port 8000 --reload",
    "dev:mac": "python3 -m uvicorn app.main:app --host 127.0.0.1 --port 8000 --reload",
    "dev:front": "npm --prefix frontend run dev",
    "build:front": "npm --prefix frontend run build",
    "dev:all:win": "start \"backend\" cmd /c npm run dev:win && start \"frontend\" cmd /c npm run dev:front",
    "dev:all:mac": "npm run dev:mac & npm run dev:front"
  }
}
