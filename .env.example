# ═══════════════════════════════════════════════════════════════════════
# TradeDog Environment Configuration
# ═══════════════════════════════════════════════════════════════════════
# Copy this to .env and fill in your values.

# ── App ──────────────────────────────────────────────────────────────
DEBUG=false
APP_VERSION=1.0.0

# ── Database ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg2://user:pass@db/trading

# ── Redis ────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Telegram Alerts (optional) ───────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Tiger Open API (MGC trading) ─────────────────────────────────────
# Get credentials at https://quant.itigerup.com/
TIGER_ID=
TIGER_ACCOUNT=
TIGER_PRIVATE_KEY=mgc_trading/tiger_private.pem
