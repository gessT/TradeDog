# ═══════════════════════════════════════════════════════════════════════
# TradeDog Environment Configuration
# ═══════════════════════════════════════════════════════════════════════
# Copy this to .env and fill in your values.

# ── App ──────────────────────────────────────────────────────────────
APP_ENV=development
DEBUG=false
APP_VERSION=1.0.0

# ── Database (Neon PostgreSQL) ───────────────────────────────────────
DATABASE_URL=postgresql+psycopg2://user:pass@host/neondb?sslmode=require

# ── Redis ────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Telegram Alerts (optional) ───────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Tiger Open API (MGC trading) ─────────────────────────────────────
# Get credentials at https://quant.itigerup.com/
TIGER_ID=
TIGER_ACCOUNT=
TIGER_PRIVATE_KEY=strategies/futures/tiger_private.pem
